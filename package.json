{
  "name": "loadgo-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "npm run clean --workspaces",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint packages/core/loadgo.js packages/core/loadgo-vanilla.js scripts/ examples/ packages/core/tests/",
    "lint:fix": "eslint --fix packages/core/loadgo.js packages/core/loadgo-vanilla.js scripts/ examples/ packages/core/tests/",
    "format": "prettier --write packages/core/loadgo.js packages/core/loadgo-vanilla.js \"scripts/**/*.js\" \"examples/**/*.js\" \"packages/core/tests/**/*.js\"",
    "format:check": "prettier --check packages/core/loadgo.js packages/core/loadgo-vanilla.js \"scripts/**/*.js\" \"examples/**/*.js\" \"packages/core/tests/**/*.js\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jquery": "^4.0.0",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "terser": "^5.46.2",
    "vitest": "^4.1.2"
  }
}
