{
  "name": "loadgo",
  "version": "3.0.0",
  "description": "A lightweight JavaScript plugin that transforms your logo into a custom progress bar.",
  "author": "Fran Verona",
  "keywords": [
    "jquery",
    "javascript",
    "plugin",
    "loadgo",
    "progress",
    "bar",
    "image"
  ],
  "homepage": "https://github.com/franverona/loadgo",
  "bugs": "https://github.com/franverona/loadgo/issues",
  "license": "MIT",
  "type": "module",
  "main": "dist/loadgo-vanilla.min.js",
  "exports": {
    ".": "./dist/loadgo-vanilla.min.js",
    "./jquery": "./dist/loadgo.min.js"
  },
  "files": [
    "dist/"
  ],
  "contributors": [
    {
      "name": "Carlos Feliciano Barba",
      "email": "c.feliciano2009@gmail.com",
      "url": "https://github.com/carloscheddar"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/franverona/loadgo.git"
  },
  "peerDependencies": {
    "jquery": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "jquery": {
      "optional": true
    }
  },
  "scripts": {
    "build": "npm run clean && npm run minify && npm run stamp",
    "clean": "rm -rf dist",
    "minify": "mkdir -p dist && terser loadgo.js -o dist/loadgo.min.js --comments /preserve/ && terser loadgo-vanilla.js -o dist/loadgo-vanilla.min.js --comments /preserve/",
    "stamp": "node scripts/stamp.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint loadgo.js loadgo-vanilla.js scripts/ examples/ tests/",
    "lint:fix": "eslint --fix loadgo.js loadgo-vanilla.js scripts/ examples/ tests/",
    "format": "prettier --write loadgo.js loadgo-vanilla.js \"scripts/**/*.js\" \"examples/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check loadgo.js loadgo-vanilla.js \"scripts/**/*.js\" \"examples/**/*.js\" \"tests/**/*.js\"",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.js": ["prettier --write"]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "jquery": "^4.0.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "terser": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
